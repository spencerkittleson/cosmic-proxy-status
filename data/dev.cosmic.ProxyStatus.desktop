[Desktop Entry]
Name=Proxy Status
Comment=Monitor HTTP proxy connection status
Type=Application
Exec=cosmic-proxy-status
Icon=dev.cosmic.ProxyStatus-symbolic
Terminal=false
Categories=COSMIC;
Keywords=COSMIC;Applet;Proxy;Network;
NoDisplay=true
X-CosmicApplet=true
X-CosmicShrinkable=false
X-CosmicHoverPopup=End
X-OverflowPriority=10
